            &lt;UnitPrice&gt;9000&lt;/UnitPrice&gt;
        &lt;/Item&gt;
    &lt;/Items&gt;

    &lt;Notes/&gt;
    &lt;Discount/&gt;
&lt;/Order&gt;</value>
