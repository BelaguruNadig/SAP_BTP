        <bpmn2:callActivity id="CallActivity_5" name="Inital Payload">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>bodyType</key>
                    <value>constant</value>
                </ifl:property>
                <ifl:property>
                    <key>propertyTable</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>headerTable</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>wrapContent</key>
                    <value>&lt;Order&gt;
    &lt;OrderID&gt;ORD-99812&lt;/OrderID&gt;
    &lt;OrderDate&gt;2025-11-26&lt;/OrderDate&gt;

    &lt;Customer&gt;
        &lt;CustomerID&gt;CUST-4421&lt;/CustomerID&gt;
        &lt;Name&gt;Deepak Stores&lt;/Name&gt;
        &lt;Country&gt;US&lt;/Country&gt;
        &lt;PriorityCustomer&gt;true&lt;/PriorityCustomer&gt;
    &lt;/Customer&gt;

    &lt;Payment&gt;
        &lt;PaymentMethod&gt;CreditCard&lt;/PaymentMethod&gt;
        &lt;TransactionStatus&gt;Success&lt;/TransactionStatus&gt;
        &lt;Amount&gt;12500&lt;/Amount&gt;
        &lt;Currency&gt;INR&lt;/Currency&gt;
    &lt;/Payment&gt;

    &lt;Shipping&gt;
        &lt;Address&gt;
            &lt;Line1&gt;12 Industrial Area&lt;/Line1&gt;
            &lt;City&gt;Pune&lt;/City&gt;
            &lt;State&gt;Maharashtra&lt;/State&gt;
            &lt;Zip&gt;411001&lt;/Zip&gt;
        &lt;/Address&gt;
        &lt;DeliveryType&gt;Express&lt;/DeliveryType&gt;
        &lt;DeliveryStatus&gt;Pending&lt;/DeliveryStatus&gt;
    &lt;/Shipping&gt;

    &lt;Items&gt;
        &lt;Item&gt;
            &lt;SKU&gt;PRD-111&lt;/SKU&gt;
            &lt;Name&gt;Wireless Mouse&lt;/Name&gt;
            &lt;Qty&gt;2&lt;/Qty&gt;
            &lt;UnitPrice&gt;700&lt;/UnitPrice&gt;
        &lt;/Item&gt;
        &lt;Item&gt;
            &lt;SKU&gt;PRD-222&lt;/SKU&gt;
            &lt;Name&gt;Keyboard&lt;/Name&gt;
            &lt;Qty&gt;1&lt;/Qty&gt;
            &lt;UnitPrice&gt;1500&lt;/UnitPrice&gt;
        &lt;/Item&gt;
        &lt;Item&gt;
            &lt;SKU&gt;PRD-333&lt;/SKU&gt;
            &lt;Name&gt;Monitor 24 inch&lt;/Name&gt;
            &lt;Qty&gt;1&lt;/Qty&gt;
            &lt;UnitPrice&gt;9000&lt;/UnitPrice&gt;
        &lt;/Item&gt;
    &lt;/Items&gt;

    &lt;Notes/&gt;
    &lt;Discount/&gt;
&lt;/Order&gt;</value>
                </ifl:property>
